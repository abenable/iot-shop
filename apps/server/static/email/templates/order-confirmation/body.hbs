{{> header title="Order Confirmed" preheader="Thank you for your order from IoTex Uganda!" }}

<!-- Hero Section -->
<mj-section background-color="#f0fdf4" padding="32px 24px">
    <mj-column>
        <mj-text align="center">
            <span style="font-size: 48px;">✅</span>
        </mj-text>
        <mj-text align="center" css-class="email-title" padding-top="16px" color="#14532d">
            Order Confirmed!
        </mj-text>
        <mj-text align="center" font-size="14px" color="#16a34a" padding-top="8px">
            Thank you for your order, {{ order.customer.firstName }}!
        </mj-text>
    </mj-column>
</mj-section>

<!-- Order Summary Cards -->
<mj-section background-color="#ffffff" padding="24px">
    <mj-column width="32%" background-color="#f9fafb" padding="12px" border-radius="6px">
        <mj-text align="center" font-size="11px" color="#6b7280" text-transform="uppercase" letter-spacing="0.5px">
            Order Number
        </mj-text>
        <mj-text align="center" font-size="14px" font-weight="600" color="#111827" padding-top="4px">
            {{ order.code }}
        </mj-text>
    </mj-column>
    <mj-column width="2%"></mj-column>
    <mj-column width="32%" background-color="#f9fafb" padding="12px" border-radius="6px">
        <mj-text align="center" font-size="11px" color="#6b7280" text-transform="uppercase" letter-spacing="0.5px">
            Date
        </mj-text>
        <mj-text align="center" font-size="14px" font-weight="600" color="#111827" padding-top="4px">
            {{ formatDate order.orderPlacedAt }}
        </mj-text>
    </mj-column>
    <mj-column width="2%"></mj-column>
    <mj-column width="32%" background-color="#f0fdf4" padding="12px" border-radius="6px">
        <mj-text align="center" font-size="11px" color="#16a34a" text-transform="uppercase" letter-spacing="0.5px">
            Total
        </mj-text>
        <mj-text align="center" font-size="14px" font-weight="600" color="#14532d" padding-top="4px">
            {{ formatMoney order.totalWithTax order.currencyCode 'en' }}
        </mj-text>
    </mj-column>
</mj-section>

<!-- Shipping Address -->
<mj-section background-color="#ffffff" padding="0 24px 24px">
    <mj-column>
        <mj-divider border-color="#e5e7eb" border-width="1px" padding="0 0 24px" />
        
        <mj-text css-class="section-heading" padding-bottom="12px">
            Shipping Address
        </mj-text>
        
        <mj-section background-color="#f9fafb" padding="16px" border-radius="6px">
            <mj-column>
                {{#with order.shippingAddress }}
                <mj-text font-size="14px" color="#374151" line-height="1.6">
                    <strong style="color: #111827;">{{ fullName }}</strong><br />
                    {{#if company}}{{ company }}<br />{{/if}}
                    {{#if streetLine1}}{{ streetLine1 }}<br />{{/if}}
                    {{#if streetLine2}}{{ streetLine2 }}<br />{{/if}}
                    {{#if city}}{{ city }}{{/if}}{{#if province}}, {{ province }}{{/if}}{{#if postalCode}} {{ postalCode }}{{/if}}<br />
                    {{#if country}}{{ country }}<br />{{/if}}
                    {{#if phoneNumber}}<span style="color: #6b7280;">📞 {{ phoneNumber }}</span>{{/if}}
                </mj-text>
                {{/with}}
            </mj-column>
        </mj-section>
    </mj-column>
</mj-section>

<!-- Order Items -->
<mj-section background-color="#ffffff" padding="0 24px 24px">
    <mj-column>
        <mj-text css-class="section-heading" padding-bottom="16px">
            Order Summary
        </mj-text>
        
        {{#each order.lines }}
        <mj-section padding="12px 0" border-bottom="1px solid #e5e7eb">
            <mj-column width="20%">
                <mj-image src="{{ featuredAsset.preview }}?w=80&h=80" alt="{{ productVariant.name }}" width="60px" height="60px" border-radius="6px" />
            </mj-column>
            <mj-column width="50%">
                <mj-text font-size="14px" font-weight="600" color="#111827" padding="0">
                    {{ productVariant.name }}
                </mj-text>
                <mj-text font-size="12px" color="#6b7280" padding="4px 0 0">
                    Qty: {{ quantity }}
                </mj-text>
            </mj-column>
            <mj-column width="30%">
                <mj-text font-size="14px" font-weight="600" color="#111827" align="right" padding="0">
                    {{ formatMoney discountedLinePriceWithTax ../order.currencyCode 'en' }}
                </mj-text>
            </mj-column>
        </mj-section>
        {{/each}}
        
        <!-- Order Totals -->
        <mj-section padding-top="16px">
            <mj-column width="60%"></mj-column>
            <mj-column width="40%">
                <mj-text font-size="13px" color="#6b7280" padding="4px 0">
                    <span style="float: left;">Subtotal:</span>
                    <span style="float: right; color: #374151;">{{ formatMoney order.subTotalWithTax order.currencyCode 'en' }}</span>
                </mj-text>
                
                {{#each shippingLines }}
                <mj-text font-size="13px" color="#6b7280" padding="4px 0">
                    <span style="float: left;">Shipping:</span>
                    <span style="float: right; color: #374151;">{{ formatMoney priceWithTax ../order.currencyCode 'en' }}</span>
                </mj-text>
                {{/each}}
                
                {{#each order.discounts }}
                <mj-text font-size="13px" color="#16a34a" padding="4px 0">
                    <span style="float: left;">Discount:</span>
                    <span style="float: right;">-{{ formatMoney amount ../order.currencyCode 'en' }}</span>
                </mj-text>
                {{/each}}
                
                <mj-divider border-color="#e5e7eb" border-width="1px" padding="8px 0" />
                
                <mj-text font-size="16px" font-weight="700" color="#111827" padding="4px 0">
                    <span style="float: left;">Total:</span>
                    <span style="float: right; color: #16a34a;">{{ formatMoney order.totalWithTax order.currencyCode 'en' }}</span>
                </mj-text>
            </mj-column>
        </mj-section>
    </mj-column>
</mj-section>

<!-- CTA Section -->
<mj-section background-color="#ffffff" padding="0 24px 32px">
    <mj-column>
        <mj-button href="https://iotex.tech/account/orders/{{ order.code }}" padding="0">
            View Order Details
        </mj-button>
        
        <mj-text align="center" padding-top="16px">
            <a href="https://iotex.tech" style="color: #16a34a; text-decoration: none; font-size: 14px;">Continue Shopping →</a>
        </mj-text>
    </mj-column>
</mj-section>

<!-- What's Next -->
<mj-section background-color="#f9fafb" padding="24px">
    <mj-column>
        <mj-text css-class="section-heading" align="center" padding-bottom="16px">
            What's Next?
        </mj-text>
        
        <mj-section padding="0">
            <mj-column width="30%">
                <mj-text align="center" font-size="28px">📦</mj-text>
                <mj-text align="center" font-size="12px" font-weight="600" color="#111827" padding-top="8px">Processing</mj-text>
                <mj-text align="center" font-size="11px" color="#6b7280">We're preparing your order</mj-text>
            </mj-column>
            <mj-column width="5%">
                <mj-text align="center" color="#d1d5db">→</mj-text>
            </mj-column>
            <mj-column width="30%">
                <mj-text align="center" font-size="28px">🚚</mj-text>
                <mj-text align="center" font-size="12px" font-weight="600" color="#111827" padding-top="8px">Shipping</mj-text>
                <mj-text align="center" font-size="11px" color="#6b7280">Delivery updates via email</mj-text>
            </mj-column>
            <mj-column width="5%">
                <mj-text align="center" color="#d1d5db">→</mj-text>
            </mj-column>
            <mj-column width="30%">
                <mj-text align="center" font-size="28px">✅</mj-text>
                <mj-text align="center" font-size="12px" font-weight="600" color="#111827" padding-top="8px">Delivered</mj-text>
                <mj-text align="center" font-size="11px" color="#6b7280">Enjoy your products!</mj-text>
            </mj-column>
        </mj-section>
        
        <mj-text align="center" font-size="13px" color="#6b7280" padding-top="24px">
            Questions? Contact us at <a href="mailto:support@iotex.tech" style="color: #16a34a;">support@iotex.tech</a>
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}

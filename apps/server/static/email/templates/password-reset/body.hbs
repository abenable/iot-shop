{{> header title="Reset Your Password" preheader="Reset your IoT Hub Uganda account password" }}

<!-- Hero Section -->
<mj-section background-color="#ffffff" padding="32px 24px 16px">
    <mj-column>
        <mj-text align="center">
            <span style="font-size: 48px;">🔒</span>
        </mj-text>
        <mj-text align="center" css-class="email-title" padding-top="16px">
            Reset Your Password
        </mj-text>
    </mj-column>
</mj-section>

<!-- Content Section -->
<mj-section background-color="#ffffff" padding="16px 24px">
    <mj-column>
        <mj-text css-class="body-large" align="center">
            We received a request to reset your password. Click the button below to create a new password for your account.
        </mj-text>
        
        <mj-button href="{{ passwordResetUrl }}?token={{ passwordResetToken }}" padding="24px 0">
            Reset Password
        </mj-button>
        
        <mj-text align="center" font-size="13px" color="#6b7280" padding-top="8px">
            This link expires in 24 hours
        </mj-text>
        
        <mj-divider border-color="#e5e7eb" border-width="1px" padding="24px 0" />
        
        <mj-text font-size="13px" color="#6b7280">
            <strong>Didn't request this?</strong> If you didn't make this request, you can safely ignore this email — your account remains secure and no changes have been made.
        </mj-text>
        
        <mj-text font-size="13px" color="#6b7280" padding-top="12px">
            If you're having trouble with the button above, copy and paste this link into your browser:
        </mj-text>
        
        <mj-text font-size="12px" color="#16a34a" style="word-break: break-all;">
            {{ passwordResetUrl }}?token={{ passwordResetToken }}
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}

# =============================================================================
# IoT Hub Uganda - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive information
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# For Docker: Use host.docker.internal to connect to host PostgreSQL
# For local dev: Use localhost

DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=iothub
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password
DB_SCHEMA=public

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment: dev | production
APP_ENV=production

# Server port (internal - always 3000 in Docker)
PORT=3000

# Secret key for cookie signing (generate a strong random string)
COOKIE_SECRET=your-super-secret-cookie-key-min-32-characters

# Admin credentials
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=your-admin-password

# =============================================================================
# STOREFRONT CONFIGURATION
# =============================================================================
# NOTE: Docker exposes these on non-standard ports to avoid conflicts:
#   - Server API: http://localhost:14080
#   - Storefront: http://localhost:14081

# API URL for storefront to connect to server
# Change this if you modify docker-compose.yml ports
VENDURE_SHOP_API_URL=http://localhost:14080/shop-api

# Channel token (default: __default_channel__)
VENDURE_CHANNEL_TOKEN=__default_channel__

# Public site URL (for SEO and links)
NEXT_PUBLIC_SITE_URL=http://localhost:14081

# Site name for SEO/metadata
NEXT_PUBLIC_SITE_NAME="IoT Hub Uganda"

# Default currency (UGX for Uganda)
NEXT_PUBLIC_DEFAULT_CURRENCY=UGX

# Secret for cache revalidation
REVALIDATION_SECRET=your-revalidation-secret

# =============================================================================
# CLOUDFLARE R2 / S3 STORAGE (Optional - for image uploads)
# =============================================================================
# Uncomment and fill if using R2 for asset storage
# If not set, images will be stored locally in Docker volume

# S3_BUCKET=iot-shop
# S3_ACCESS_KEY_ID=your-r2-access-key-id
# S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_REGION=auto
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# S3_FILE_URL=https://your-custom-domain.com/

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# For sending order confirmations, password resets, etc.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL="IoT Hub Uganda <noreply@iothub.ug>"

# =============================================================================
# NOTES
# =============================================================================
# - This platform is configured for UGANDA ONLY
# - Currency: UGX (Ugandan Shilling)
# - Country: Uganda only
# - Tax rates: Standard (10%) and Zero (0%)
# - Language: English only
# - Exposed ports: 14080 (server), 14081 (storefront)
# 
# After setting up .env:
# 1. Start PostgreSQL on your host
# 2. Create database: createdb iothub
# 3. Run: docker-compose up -d
# 4. Access admin: http://localhost:14080/dashboard
# 5. Access storefront: http://localhost:14081
# =============================================================================

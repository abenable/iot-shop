# IoT Shop Production Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=database
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=postgres
DB_PASSWORD=change-this-strong-password
DB_SCHEMA=public

# ============================================
# Application Configuration
# ============================================
APP_ENV=production
PORT=3000
COOKIE_SECRET=generate-a-secure-random-string-here
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change-this-admin-password

# ============================================
# Storefront Configuration
# ============================================
VENDURE_SHOP_API_URL=http://localhost:3000/shop-api
VENDURE_CHANNEL_TOKEN=__default_channel__
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_CURRENCY=UGX
REVALIDATION_SECRET=another-secure-random-string

# ============================================
# CloudFlare R2 Storage (Optional)
# Uncomment and configure to use R2 for assets
# ============================================
# S3_BUCKET=iot-shop
# S3_ACCESS_KEY_ID=your-r2-access-key
# S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true
# S3_FILE_URL=https://your-custom-domain.com/

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL="IoT Shop <noreply@yourdomain.com>"

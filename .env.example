# IoT Hub Uganda - Production Environment Configuration
# Copy this file to .env and fill in your actual values
# This is a Uganda-only platform - UGX currency, Uganda shipping, English language only

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=database
DB_PORT=5432
DB_NAME=iothub
DB_USERNAME=postgres
DB_PASSWORD=change-this-strong-password
DB_SCHEMA=public

# ============================================
# Application Configuration
# ============================================
APP_ENV=production
PORT=3000
COOKIE_SECRET=generate-a-secure-random-string-here
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change-this-admin-password

# ============================================
# Storefront Configuration (Uganda Only)
# ============================================
VENDURE_SHOP_API_URL=http://localhost:3000/shop-api
VENDURE_CHANNEL_TOKEN=__default_channel__
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_CURRENCY=UGX
NEXT_PUBLIC_SITE_NAME="IoT Hub Uganda"
REVALIDATION_SECRET=another-secure-random-string

# ============================================
# CloudFlare R2 Storage (Optional)
# ============================================
# S3_BUCKET=iot-shop
# S3_ACCESS_KEY_ID=your-r2-access-key
# S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true
# S3_FILE_URL=https://iot-r2.byte10x.dev/

# ============================================
# Email Configuration (Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL="IoT Hub Uganda <noreply@iothub.ug>"
